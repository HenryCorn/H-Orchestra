{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "./init.sh >> /tmp/harness_init.log 2>&1 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./init.sh >> /tmp/harness_init.log 2>&1 || true"
          }
        ]
      }
    ]
  }
}
